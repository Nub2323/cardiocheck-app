generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id        String    @id @default(cuid())
  name      String
  dni       String    @unique
  birthDate DateTime? // Fecha de nacimiento - verificación de identidad
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  checkIns  CheckIn[]
}

model CheckIn {
  id        String          @id @default(cuid())
  patientId String
  patient   Patient         @relation(fields: [patientId], references: [id])
  comment   String?
  severity  String          @default("green") // overall severity: green, neutral, yellow, red
  createdAt DateTime        @default(now())
  answers   CheckInAnswer[]
  alert     Alert?
}

model CheckInAnswer {
  id           String   @id @default(cuid())
  checkInId    String
  checkIn      CheckIn  @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  questionIndex Int
  question     String
  answer       String
  severity     String // green, neutral, yellow-low, yellow, yellow-high, red
}

model Alert {
  id        String   @id @default(cuid())
  checkInId String   @unique
  checkIn   CheckIn  @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  status    String   @default("pending") // pending, acknowledged, dismissed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminPin {
  id    String @id @default(cuid())
  pin   String @unique
  label String?
}
